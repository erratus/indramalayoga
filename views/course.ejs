<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Courses</title>
    <link rel="stylesheet" href="/static/styles/courses.css"> 
    <link rel="icon" type="image/x-icon" href="/static/assets/favicon.ico">
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-11548243331"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', 'AW-11548243331'); </script>
</head>
<body>
    <div class="header">
        <div class="logo">
            <div class="logo">
                <img src="/static/assets/website_icon.webp" alt="" srcset="">
            </div>
        </div>
        <div class="header1">
            <p class="head-txt">MANAGE COURSES</p>
        </div>
    </div>
    <div class="container">
        <div class="ext-courses">
            <h3>EXISTING COURSES</h3>
            <hr>
            <table>
                <thead>
                    <tr>
                        <th>Course Name</th>
                        <th>Price</th>
                        <th>Date Details</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% courses.forEach(course => { %>
                    <tr>
                        <td><%= course.Course_name %></td>
                        <td>$<%= course.Price %></td>
                        <td>
                            <div class="date-row">
                                <div>
                                    <label for="from_date_<%= course.CID %>">Start Date:</label>
                                    <input type="date" id="from_date_<%= course.CID %>" name="from_date" value="<%= course.from_date %>" required>
                                </div>
                                <div>
                                    <label for="to_date_<%= course.CID %>">End Date:</label>
                                    <input type="date" id="to_date_<%= course.CID %>" name="to_date" value="<%= course.to_date %>" required>
                                </div>
                            </div>
                            <form action="/edit_course" method="POST" style="margin-top: 10px;">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="course_id" value="<%= course.CID %>">
                                <button type="submit">Update Dates</button>
                            </form>
                        </td>
                        <td>
                            <form action="/delete_course/<%= course.CID %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this course?');">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="new-courses">
            <h3>ADD NEW COURSE</h3>
            <hr>
            <form action="/edit_course" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label for="course_name">Course Name:</label>
                <input type="text" id="course_name" name="course_name" required>

                <label for="price">Price:</label>
                <input type="number" step="0.01" id="price" name="price" required>

                <label for="from_date">Start Date:</label>
                <input type="date" id="from_date" name="from_date" required>

                <label for="to_date">End Date:</label>
                <input type="date" id="to_date" name="to_date" required>
                
                <button class="submit" type="submit">Add Course</button>
            </form>
        </div>
    </div>
    <script>
        window.addEventListener('load', function() { document.body.classList.add('loaded'); });
    </script>
</body>
</html>

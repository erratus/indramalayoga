<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Instructors</title>
    <link rel="stylesheet" href="/static/styles/instructors.css">
    <link rel="icon" type="image/x-icon" href="/static/assets/favicon.ico">
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-11548243331"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', 'AW-11548243331'); </script>
</head>
<body>
    <div class="header">
        <div class="logo">
            <img src="/static/assets/website_icon.webp" alt="Logo">
        </div>
        <div class="header1">
            <p class="head-txt">MANAGE INSTRUCTORS</p>
        </div>
    </div>
    <div class="container">
        <div class="ext-inst">
            <h3>EXISTING INSTRUCTORS AND ASSIGNED COURSES</h3>
            <hr>
            <br>
            <table>
                <thead>
                    <tr>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Phone no.</th>
                        <th>Address</th>
                        <th>Learning Courses</th>
                        <th>Assigned Courses</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% instructors.forEach(instructor => { %>
                    <tr>
                        <td><%= instructor.name %></td>
                        <td><%= instructor.lastname %></td>
                        <td><%= instructor.phone %></td>
                        <td><%= instructor.address %></td>
                        <td>
                            <ul>
                                <% instructor.learning_courses.forEach(lc => { %>
                                <li><%= lc %></li>
                                <% }) %>
                            </ul>
                        </td>
                        <td>
                            <ul>
                                <% instructor.courses.forEach(course => { %>
                                <li>
                                    <%= course.name %>
                                    <form action="/remove_instructor_course/<%= instructor.tid %>/<%= course.cid %>" method="POST" style="display:inline;">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="remove-btn">Remove</button>
                                    </form>
                                </li>
                                <% }) %>
                            </ul>
                        </td>
                        <td>
                            <form action="/add_instructor_course/<%= instructor.tid %>" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <select name="course" required>
                                    <option value="" disabled selected>Select a course</option>
                                    <% all_courses.forEach(c => { %>
                                    <option value="<%= c.CID %>"><%= c.Course_name %></option>
                                    <% }) %>
                                </select>
                                <button type="submit">Add Course</button>
                            </form>
                            <form action="/delete_instructor_enrollment/<%= instructor.tid %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this instructor?');">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="delete-btn">Delete Instructor</button>
                            </form>
                        </td>                        
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <script>
        window.addEventListener('load', function() { document.body.classList.add('loaded'); });
    </script>
</body>
</html>
